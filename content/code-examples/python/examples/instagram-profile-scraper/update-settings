import requests

API_KEY = "YOUR_API_KEY"
BASE_URL = "https://api.lobstr.io/v1"
headers = {"Authorization": f"Token {API_KEY}"}

squid_id = "YOUR_SQUID_HASH"

# Update squid settings
payload = {
    "name": "Instagram Profile Scraper (1)",
    "concurrency": 5,
    "export_unique_results": True,
    "to_complete": False,
    "no_line_breaks": True,
    "params": {
        "max_results": 100,                # Max profiles per task
        "max_unique_results_per_run": 1000 # Total unique profiles limit
    }
}

response = requests.post(f"{BASE_URL}/squids/{squid_id}",
    headers=headers,
    json=payload
)

print(f"Settings updated: {response.json()['name']}")

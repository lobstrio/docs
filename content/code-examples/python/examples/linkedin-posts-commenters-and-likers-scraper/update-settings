import requests

API_KEY = "YOUR_API_KEY"
BASE_URL = "https://api.lobstr.io/v1"
headers = {"Authorization": f"Token {API_KEY}"}

squid_id = "YOUR_SQUID_HASH"

# Update squid settings
payload = {
    "name": "LinkedIn Posts Commenters and Likers Scraper (1)",
    "concurrency": 5,
    "export_unique_results": True,
    "to_complete": False,
    "no_line_breaks": True,
    "params": {
        "scrape_comments": True,    # Scrape users who commented
        "scrape_reactions": True,   # Scrape users who reacted/liked
        "email_enrichment": False              # Disable email enrichment
    }
}

response = requests.post(f"{BASE_URL}/squids/{squid_id}",
    headers=headers,
    json=payload
)

print(f"Settings updated: {response.json()['name']}")
